# Server
PORT=4100
NODE_ENV=development

# Database
DATABASE_URL="postgresql://qr_user:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5434/qr_tickets?schema=public"
DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=qr_tickets
DB_USER=qr_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Frontend base URL (used for QR code links and CORS)
PUBLIC_BASE_URL="http://localhost:5174"

# Admin panel key (required — set a strong random value)
ADMIN_PANEL_KEY="replace-with-strong-internal-key"

# Email / SMTP (leave blank to disable email sending in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="no-reply@localhost"

# AWS S3 — evidence image storage (leave blank to store in DB instead)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Production: use Amazon SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=<AWS SES SMTP user>
# SMTP_PASS=<AWS SES SMTP password>
# MAIL_FROM=no-reply@connsura.com

# Sentry (optional, leave blank to disable error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
