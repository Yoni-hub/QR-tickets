# Server
PORT=4100
NODE_ENV=development

# Database
DATABASE_URL="postgresql://qr_user:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5434/qr_tickets?schema=public"
DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=qr_tickets
DB_USER=qr_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Frontend base URL (used for QR code links and CORS)
PUBLIC_BASE_URL="http://localhost:5174"

# Admin panel key (required — set a strong random value)
ADMIN_PANEL_KEY="replace-with-strong-internal-key"

# Email / SMTP (leave blank to disable email sending in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="no-reply@localhost"

# AWS S3 — evidence image storage (leave blank to store in DB instead)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Production: use Amazon SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=<AWS SES SMTP user>
# SMTP_PASS=<AWS SES SMTP password>
# MAIL_FROM=no-reply@connsura.com

# Sentry (optional, leave blank to disable error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Integrations (TikTok OAuth)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Default: https://qr-tickets.connsura.com/tiktok/callback
TIKTOK_REDIRECT_URI=
# 32-byte base64 key for encrypting integration tokens at rest (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
TOKEN_ENCRYPTION_KEY=

# Promo automation (optional)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL="gpt-5.2"
OPENAI_TEXT_TEMPERATURE=1.0
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TTS_VOICE="marin"

# Free stock b-roll (optional). If keys are not set, video rendering falls back to motion-graphics backgrounds.
# Pexels Video API key: https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay Video API key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Comma-separated provider order (defaults: pexels,pixabay)
PROMO_BROLL_PROVIDERS="pexels,pixabay"
# Comma-separated query list used for random b-roll selection
PROMO_BROLL_QUERIES="event entrance,concert entrance,ticket scanning,qr code scan,people scanning qr code,crowd at event,busy check in,smartphone qr code"
# Max b-roll download size per clip (MB)
PROMO_BROLL_MAX_MB=70
# Number of stock images to use when building image-based scenes (1-4)
PROMO_BROLL_IMAGE_COUNT=3

# Promo video template: "auto" (prefer b-roll when available), "broll", or "motion"
PROMO_VIDEO_TEMPLATE="auto"

# Optional: override FFmpeg binary path for local dev (Windows) if `ffmpeg` isn't on PATH
FFMPEG_PATH=
