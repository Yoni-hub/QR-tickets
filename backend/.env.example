# Server
PORT=4100
NODE_ENV=development

# Database
DATABASE_URL="postgresql://qr_user:qr_pass@127.0.0.1:5434/qr_tickets?schema=public"
DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=qr_tickets
DB_USER=qr_user
DB_PASSWORD=qr_pass

# Frontend base URL (used for QR code links and CORS)
PUBLIC_BASE_URL="http://localhost:5174"

# Admin panel key (required — set a strong random value)
ADMIN_PANEL_KEY="replace-with-strong-internal-key"

# Email / SMTP (leave blank to disable email sending in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="no-reply@localhost"

# Production: use Amazon SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=<AWS SES SMTP user>
# SMTP_PASS=<AWS SES SMTP password>
# MAIL_FROM=no-reply@connsura.com
