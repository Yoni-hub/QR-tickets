generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserEvent {
  id          String      @id @default(cuid())
  organizerName String?
  eventName   String
  eventDate   DateTime
  eventAddress String
  slug        String?     @unique
  ticketType  String?
  ticketPrice Decimal?    @db.Decimal(10, 2)
  paymentInstructions String?
  designJson  Json?
  adminStatus EventAdminStatus @default(ACTIVE)
  adminDisabledAt DateTime?
  archivedAt  DateTime?
  quantity    Int
  accessCode  String      @unique
  organizerAccessCode String?
  isDemo      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tickets     Ticket[]
  scanRecords ScanRecord[]
  auditLogs   AdminAuditLog[]
  ticketRequests TicketRequest[]
  promoters   Promoter[]
  supportConversations SupportConversation[]

  @@index([organizerAccessCode])
}

model Ticket {
  id             String       @id @default(cuid())
  eventId        String
  ticketPublicId String       @unique
  qrPayload      String
  ticketType     String?
  ticketPrice    Decimal?     @db.Decimal(10, 2)
  designJson     Json?
  attendeeName   String?
  attendeePhone  String?
  attendeeEmail  String?
  promoterId     String?
  ticketRequestId String?
  status         TicketStatus @default(UNUSED)
  isInvalidated  Boolean      @default(false)
  invalidatedAt  DateTime?
  cancelledAt    DateTime?
  cancellationReason String?
  cancellationOtherReason String?
  cancellationEvidenceImageDataUrl String?
  scannedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  event          UserEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  promoter       Promoter?    @relation(fields: [promoterId], references: [id], onDelete: SetNull)
  ticketRequest  TicketRequest? @relation(fields: [ticketRequestId], references: [id], onDelete: SetNull)
  scanRecords    ScanRecord[]
  deliveries     TicketDelivery[]
  viewLogs       TicketViewLog[]

  @@index([eventId])
  @@index([promoterId])
  @@index([ticketRequestId])
}

model TicketDelivery {
  id           String         @id @default(cuid())
  ticketId     String
  email        String
  method       DeliveryMethod @default(EMAIL_LINK)
  status       DeliveryStatus
  sentAt       DateTime       @default(now())
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ticket       Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([sentAt])
}

model ScanRecord {
  id          String      @id @default(cuid())
  eventId      String
  ticketId     String?
  ticketPublicId String
  rawScannedValue String?
  normalizedTicketPublicId String?
  scannerSource String?
  note        String?
  result       ScanResult
  scannedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  event        UserEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket       Ticket?     @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([ticketPublicId])
}

enum TicketStatus {
  UNUSED
  USED
}

enum EventAdminStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum ScanResult {
  VALID
  USED
  INVALID
}

enum DeliveryMethod {
  EMAIL_LINK
  PDF_DOWNLOAD
}

enum DeliveryStatus {
  SENT
  FAILED
}

model Promoter {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     UserEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets   Ticket[]
  ticketRequests TicketRequest[]

  @@unique([eventId, code])
  @@index([eventId])
}

model TicketRequest {
  id         String   @id @default(cuid())
  clientAccessToken String? @unique
  eventId    String
  name       String
  phone      String?
  email      String?
  ticketType String?
  ticketPrice Decimal? @db.Decimal(10, 2)
  totalPrice Decimal? @db.Decimal(10, 2)
  ticketSelections Json?
  evidenceImageDataUrl String?
  organizerMessage String?
  cancelledAt DateTime?
  cancellationReason String?
  cancellationOtherReason String?
  cancellationEvidenceImageDataUrl String?
  quantity   Int
  promoterId String?
  status     TicketRequestStatus @default(PENDING_PAYMENT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      UserEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  promoter   Promoter? @relation(fields: [promoterId], references: [id], onDelete: SetNull)
  tickets    Ticket[]
  messages   TicketRequestMessage[]

  @@index([eventId])
  @@index([promoterId])
  @@index([status])
}

model TicketRequestMessage {
  id             String @id @default(cuid())
  ticketRequestId String
  senderType     TicketRequestMessageSender
  message        String
  evidenceImageDataUrl String?
  readAt         DateTime?
  createdAt      DateTime @default(now())
  ticketRequest  TicketRequest @relation(fields: [ticketRequestId], references: [id], onDelete: Cascade)

  @@index([ticketRequestId, createdAt])
  @@index([ticketRequestId, readAt])
}

enum TicketRequestStatus {
  PENDING_PAYMENT
  APPROVED
  REJECTED
  CANCELLED
}

enum TicketRequestMessageSender {
  ORGANIZER
  CLIENT
}

model TicketViewLog {
  id        String   @id @default(cuid())
  ticketId  String
  source    String?
  userAgent String?
  ipAddress String?
  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([openedAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  metadata   Json?
  eventId    String?
  createdAt  DateTime @default(now())
  event      UserEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([eventId])
}

model SupportConversation {
  id                String                 @id @default(cuid())
  conversationToken String                 @unique
  eventId           String?
  displayName       String?
  email             String?
  accessCode        String?
  status            SupportConversationStatus @default(OPEN)
  lastMessageAt     DateTime               @default(now())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  event             UserEvent?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  messages          SupportMessage[]

  @@index([status, lastMessageAt])
  @@index([eventId])
  @@index([accessCode])
}

model SupportMessage {
  id                  String               @id @default(cuid())
  conversationId      String
  senderType          SupportMessageSender
  message             String
  evidenceImageDataUrl String?
  readAt              DateTime?
  createdAt           DateTime             @default(now())
  conversation        SupportConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
}

enum SupportConversationStatus {
  OPEN
  CLOSED
}

enum SupportMessageSender {
  VISITOR
  ADMIN
}
