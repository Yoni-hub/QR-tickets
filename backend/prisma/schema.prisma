generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserEvent {
  id          String      @id @default(cuid())
  eventName   String
  eventDate   DateTime
  eventAddress String
  ticketType  String?
  ticketPrice Decimal?    @db.Decimal(10, 2)
  designJson  Json?
  adminStatus EventAdminStatus @default(ACTIVE)
  adminDisabledAt DateTime?
  archivedAt  DateTime?
  quantity    Int
  accessCode  String      @unique
  isDemo      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tickets     Ticket[]
  scanRecords ScanRecord[]
  auditLogs   AdminAuditLog[]
}

model Ticket {
  id             String       @id @default(cuid())
  eventId        String
  ticketPublicId String       @unique
  qrPayload      String
  status         TicketStatus @default(UNUSED)
  isInvalidated  Boolean      @default(false)
  invalidatedAt  DateTime?
  scannedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  event          UserEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scanRecords    ScanRecord[]
  deliveries     TicketDelivery[]
  viewLogs       TicketViewLog[]

  @@index([eventId])
}

model TicketDelivery {
  id           String         @id @default(cuid())
  ticketId     String
  email        String
  method       DeliveryMethod @default(EMAIL_LINK)
  status       DeliveryStatus
  sentAt       DateTime       @default(now())
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ticket       Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([sentAt])
}

model ScanRecord {
  id          String      @id @default(cuid())
  eventId      String
  ticketId     String?
  ticketPublicId String
  rawScannedValue String?
  normalizedTicketPublicId String?
  scannerSource String?
  note        String?
  result       ScanResult
  scannedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  event        UserEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket       Ticket?     @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([ticketPublicId])
}

enum TicketStatus {
  UNUSED
  USED
}

enum EventAdminStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum ScanResult {
  VALID
  USED
  INVALID
}

enum DeliveryMethod {
  EMAIL_LINK
}

enum DeliveryStatus {
  SENT
  FAILED
}

model TicketViewLog {
  id        String   @id @default(cuid())
  ticketId  String
  source    String?
  userAgent String?
  ipAddress String?
  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([openedAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  metadata   Json?
  eventId    String?
  createdAt  DateTime @default(now())
  event      UserEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([eventId])
}
